generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ─────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  password        String?   // Hashed (for credentials login)
  isPremium       Boolean   @default(false)
  premiumUntil    DateTime?
  stripeCustomerId String?
  createdAt       DateTime  @default(now())
  accounts        Account[]
  sessions        Session[]
  priceAlerts     PriceAlert[] @relation("UserAlerts")
  reputationScore Int          @default(0)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── Application Models ───────────────────────────────────────────────────────

model Product {
  id          Int              @id @default(autoincrement())
  brand       String?
  model       String?
  baseName    String           // Normalized base name (e.g., "Apple iPhone 15 Pro")
  category    String?
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductVariant {
  id          Int              @id @default(autoincrement())
  productId   Int
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes  Json             // { "storage": "256GB", "color": "Titanium" }
  matchGroup  MatchGroup?
}

model MatchGroup {
  id              Int               @id @default(autoincrement())
  variantId       Int               @unique
  variant         ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  canonicalName   String            // "Apple iPhone 15 Pro 256GB Titanium"
  confidenceScore Float             // AI confidence of this grouping (0-100)
  listings        PlatformListing[]
  aiAnalysis      AiAnalysis?
  priceAlerts     PriceAlert[]
  trustScore      Float             @default(50.0)
  fakeDiscountRate Float            @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model PlatformListing {
  id              Int            @id @default(autoincrement())
  matchGroupId    Int?
  matchGroup      MatchGroup?    @relation(fields: [matchGroupId], references: [id])
  platform        String         // "trendyol" | "hepsiburada" | "amazon"
  url             String         @unique
  externalId      String?
  rawTitle        String         // Original scraped title
  image           String?
  isActive        Boolean        @default(true)
  sellerId        Int?
  seller          Seller?        @relation(fields: [sellerId], references: [id])
  prices          PriceHistory[]
  reviews         Review[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([matchGroupId])
  @@index([platform])
}

model PriceHistory {
  id          Int             @id @default(autoincrement())
  listingId   Int
  listing     PlatformListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  price       Float
  oldPrice    Float?
  shippingCost Float?         @default(0)
  isAnomaly   Boolean         @default(false)
  createdAt   DateTime        @default(now())

  @@index([listingId])
  @@index([createdAt])
}

model Review {
  id          Int             @id @default(autoincrement())
  listingId   Int
  listing     PlatformListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author      String?
  rating      Int?
  text        String
  date        DateTime?
  sentiment   Float?          // -1.0 to 1.0
  isFake      Boolean         @default(false)
  flags       String[]        // Array of detected anomalies
  aspectSentiment Json?       // Aspect-based sentiment analysis scores
  createdAt   DateTime        @default(now())

  @@index([listingId])
}

model AiAnalysis {
  id            Int         @id @default(autoincrement())
  matchGroupId  Int         @unique
  matchGroup    MatchGroup  @relation(fields: [matchGroupId], references: [id], onDelete: Cascade)
  decision      String      // "BUY" | "WAIT" | "AVOID"
  reasoning     String
  riskFactors   String[]
  trustScore    Float
  marketValue   Float?      // Estimated true value based on history
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Seller {
  id                Int               @id @default(autoincrement())
  platform          String
  name              String
  trustScore        Float             @default(100.0) // 100 üzerinden başlar
  fakeDiscountCount Int               @default(0)
  listings          PlatformListing[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([platform, name])
}

model PriceAlert {
  id              Int               @id @default(autoincrement())
  matchGroupId    Int
  matchGroup      MatchGroup        @relation(fields: [matchGroupId], references: [id])
  targetPrice     Float
  email           String?
  userId          String?           // NextAuth user bağlantısı (isteğe bağlı)
  user            User?             @relation("UserAlerts", fields: [userId], references: [id])
  telegramChatId  String?           // Telegram bildirim için chat ID
  whatsappNumber  String?           // WhatsApp bildirim için telefon numarası
  isTriggered     Boolean           @default(false)
  notifiedAt      DateTime?
  createdAt       DateTime          @default(now())
}


model WebPushSubscription {
  id          Int      @id @default(autoincrement())
  endpoint    String   @unique
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())
}

model Brochure {
  id          Int            @id @default(autoincrement())
  storeName   String         // "BİM", "A101", "ŞOK" vb.
  title       String         // "12 Mayıs Aktüel Ürünleri"
  startDate   DateTime
  endDate     DateTime
  imageUrl    String?
  items       BrochureItem[]
  createdAt   DateTime       @default(now())
}

model BrochureItem {
  id          Int        @id @default(autoincrement())
  brochureId  Int
  brochure    Brochure   @relation(fields: [brochureId], references: [id], onDelete: Cascade)
  name        String     // Ürün adı
  price       Float
  imageUrl    String?
  category    String?
  createdAt   DateTime   @default(now())
}

model AffiliateClick {
  id          Int      @id @default(autoincrement())
  platform    String   // trendyol | hepsiburada | amazon
  productId   Int?
  url         String
  createdAt   DateTime @default(now())
}

